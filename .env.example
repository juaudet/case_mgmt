# ── Backend ─────────────────────────────────────────────────────────────────
# In Docker Compose, prefer *_FILE paths (see README). For local `uvicorn`, plain vars are fine.
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/siem
# MONGODB_URL_FILE=/run/secrets/mongodb_url
REDIS_URL=redis://localhost:6379
# REDIS_URL_FILE=/run/secrets/redis_url
JWT_SECRET_KEY=<64-char random hex — openssl rand -hex 32>
# JWT_SECRET_KEY_FILE=/run/secrets/jwt_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# ANTHROPIC_API_KEY=sk-ant-...   # optional local dev without Docker secrets
ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic_api_key
DEMO_MODE=true                    # true = use mock fixtures, no live API calls
MCP_SERVER_URL=http://localhost:8001

# ── MCP Server ───────────────────────────────────────────────────────────────
# Optional live VirusTotal mode for MCP sidecar. Prefer Docker secret file in local compose.
VT_API_KEY_FILE=/run/secrets/vt_api_key
CS_CLIENT_ID_FILE=/run/secrets/cs_client_id
CS_CLIENT_SECRET_FILE=/run/secrets/cs_client_secret
OTX_API_KEY_FILE=/run/secrets/otx_api_key
LDAP_HOST=ldap://10.0.0.1
LDAP_BIND_DN=cn=svc-siem,ou=service-accounts,dc=corp,dc=local
LDAP_BIND_PASSWORD_FILE=/run/secrets/ldap_bind_password
LDAP_BASE_DN=dc=corp,dc=local

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# NEXTAUTH_SECRET=...   # local dev; Docker image reads NEXTAUTH_SECRET_FILE via entrypoint
NEXTAUTH_SECRET_FILE=/run/secrets/nextauth_secret
NEXTAUTH_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://api.your-domain.com
